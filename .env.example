# ============================================
# 시글담 (Sigeuldam) Environment Variables
# Copy this file to .env.local and fill in real values
# ============================================

# ─── App ───
NEXT_PUBLIC_BASE_URL=https://sigeuldam.kr
NEXTAUTH_URL=https://sigeuldam.kr
NEXTAUTH_SECRET=your-random-secret-key-change-this

# ─── Supabase ───
# 1. Go to https://supabase.com → Create project
# 2. Copy from Settings > API
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key

# ─── OpenAI (for AI poem auto-completion) ───
# Get key from https://platform.openai.com/api-keys
OPENAI_API_KEY=sk-...
OPENAI_BASE_URL=https://api.openai.com/v1

# ─── Kakao Login ───
# 1. Get business registration certificate (사업자등록증)
# 2. Go to https://developers.kakao.com
# 3. Create app → Settings → Kakao Login → Enable
# 4. Set redirect URI: https://sigeuldam.kr/api/auth/callback/kakao
KAKAO_CLIENT_ID=your-kakao-rest-api-key
KAKAO_CLIENT_SECRET=your-kakao-client-secret

# ─── Naver Login ───
# 1. Get business registration certificate (사업자등록증)
# 2. Go to https://developers.naver.com
# 3. Create app → Login API → Set callback URL
# 4. Set callback URL: https://sigeuldam.kr/api/auth/callback/naver
NAVER_CLIENT_ID=your-naver-client-id
NAVER_CLIENT_SECRET=your-naver-client-secret

# ─── Toss Payments ───
# 1. Get business registration certificate (사업자등록증)
# 2. Go to https://developers.tosspayments.com
# 3. Sign up → Get test keys first, then production keys
NEXT_PUBLIC_TOSS_CLIENT_KEY=test_ck_...
TOSS_SECRET_KEY=test_sk_...

# ─── Email (Resend) ───
# 1. Go to https://resend.com → Sign up
# 2. Verify your domain (sigeuldam.kr)
# 3. Get API key
RESEND_API_KEY=re_...

# ─── Google AdSense ───
# 1. Get business registration certificate (사업자등록증)
# 2. Go to https://www.google.com/adsense
# 3. Sign up → Verify site → Get publisher ID
NEXT_PUBLIC_ADSENSE_CLIENT_ID=ca-pub-your-adsense-id

# ─── Admin ───
ADMIN_EMAIL=admin@sigeuldam.kr
ADMIN_FROM_EMAIL=alerts@sigeuldam.kr
